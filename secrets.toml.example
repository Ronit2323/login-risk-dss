# Copy this file to .streamlit/secrets.toml for LOCAL testing only.
# On Streamlit Community Cloud, do NOT upload this file - instead paste the
# same key = "value" lines into the app's Settings -> Secrets box in the
# dashboard (see README.md, Streamlit Cloud deployment steps).

SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "youraddress@gmail.com"
SMTP_PASSWORD = "your_16_char_app_password"
